{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://blu-org.onrender.com/api/$1" },
    { "source": "/socket.io/(.*)", "destination": "https://blu-org.onrender.com/socket.io/$1" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/register", "destination": "/index.html" }
  ]
}
